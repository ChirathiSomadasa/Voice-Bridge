<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1">

    <!-- ── Scrollable main content ─────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/miniGameScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/miniGameRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="-1dp"
            android:layout_marginRight="-1dp"
            android:paddingTop="0dp"
            android:paddingBottom="40dp">

            <!-- ── Header banner (matches activity_sequence style) ──────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#FFCC80">

                <ImageView
                    android:id="@+id/miniGameBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/activity_sequence"
                    android:alpha="0.85" />

                <!-- Dim overlay so text is readable over image -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#55000000" />

                <!-- Title text on banner -->
                <LinearLayout
                    android:layout_width="388dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/miniGameTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/rounded_button_background"
                        android:letterSpacing="0.12"
                        android:paddingLeft="14dp"
                        android:paddingTop="6dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="6dp"
                        android:text=" WHAT'S MISSING"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </FrameLayout>

            <!-- ── Instruction card ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/instructionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/instruction_background"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/instructionIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="💡"
                    android:textSize="24sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/miniGameInstruction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="One step is hiding! Can you find it?"
                    android:textSize="17sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

            <!-- ── Progress indicator (Connect the Dots only) ───────────── -->
            <LinearLayout
                android:id="@+id/progressSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:text="Tap next:"
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/progressDotText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />

            </LinearLayout>

            <!-- ── SEQUENCE ROW — shown in both games ────────────────────── -->
            <!--    What's Missing : one card is replaced by "?" placeholder  -->
            <!--    Connect Dots   : all cards visible, numbered for tapping   -->
            <LinearLayout
                android:id="@+id/sequenceRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:weightSum="3">

                <!-- Card 1 -->
                <FrameLayout
                    android:id="@+id/seqCard1"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp">

                    <ImageView
                        android:id="@+id/seqImg1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="12dp" />

                    <!-- Number badge -->
                    <TextView
                        android:id="@+id/seqBadge1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="1"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/circle_badge"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp" />

                    <!-- "?" placeholder (shown when this card is hidden) -->
                    <TextView
                        android:id="@+id/seqQuestion1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="?"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B6B"
                        android:gravity="center"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Card 2 -->
                <FrameLayout
                    android:id="@+id/seqCard2"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp">

                    <ImageView
                        android:id="@+id/seqImg2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="12dp" />

                    <TextView
                        android:id="@+id/seqBadge2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="2"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/circle_badge"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp" />

                    <TextView
                        android:id="@+id/seqQuestion2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="?"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B6B"
                        android:gravity="center"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Card 3 -->
                <FrameLayout
                    android:id="@+id/seqCard3"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp">

                    <ImageView
                        android:id="@+id/seqImg3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="12dp" />

                    <TextView
                        android:id="@+id/seqBadge3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="3"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/circle_badge"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp" />

                    <TextView
                        android:id="@+id/seqQuestion3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="?"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B6B"
                        android:gravity="center"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

            <!-- ── Section label (dynamically updated) ──────────────────── -->
            <TextView
                android:id="@+id/optionSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap the missing step:"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <!-- ── Options grid — What's Missing answer buttons ──────────── -->
            <!--    For Connect the Dots this section is hidden (gone)        -->
            <GridLayout
                android:id="@+id/optionsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="8dp">

                <!-- Option A -->
                <FrameLayout
                    android:id="@+id/optionA"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/optionAImg"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:scaleType="centerInside" />

                        <TextView
                            android:id="@+id/optionALabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step A"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Option B -->
                <FrameLayout
                    android:id="@+id/optionB"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/optionBImg"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:scaleType="centerInside" />

                        <TextView
                            android:id="@+id/optionBLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step B"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Option C -->
                <FrameLayout
                    android:id="@+id/optionC"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/optionCImg"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:scaleType="centerInside" />

                        <TextView
                            android:id="@+id/optionCLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step C"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Option D -->
                <FrameLayout
                    android:id="@+id/optionD"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    android:background="@drawable/rounded_card_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/optionDImg"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:scaleType="centerInside" />

                        <TextView
                            android:id="@+id/optionDLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step D"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

            </GridLayout>

            <!-- ── Skip button ───────────────────────────────────────────── -->
            <Button
                android:id="@+id/btnSkipMiniGame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Skip mini-game"
                android:textSize="14sp"
                android:textColor="#888888"
                android:backgroundTint="@android:color/transparent"
                android:alpha="0.7"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Full-screen feedback overlay ─────────────────────────────────── -->
    <!--    Shown briefly on correct / wrong answer before auto-dismiss      -->
    <FrameLayout
        android:id="@+id/feedbackOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:background="@drawable/rounded_card_background"
            android:elevation="4dp">

            <TextView
                android:id="@+id/feedbackEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="64sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/feedbackMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="That's it! Well done!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="center" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>