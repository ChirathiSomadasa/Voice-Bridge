<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/staircaseContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/activity_scorebaord_bg"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/therapeuticMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Score"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- Motivational Quote -->
    <TextView
        android:id="@+id/motivationalQuote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textStyle="italic"
        android:textColor="@color/colorAccent"
        android:gravity="center"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@+id/therapeuticMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Stairs Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/stairsWrapper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/motivationalQuote"
        app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/starCharacter"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/score_star"
            android:visibility="invisible"
            android:elevation="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="20dp"/>

        <ImageView
            android:id="@+id/stepBlock1"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/stepLabel1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step by step!"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock1"
            app:layout_constraintStart_toStartOf="@+id/stepBlock1"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock1"/>

        <ImageView
            android:id="@+id/stepBlock2"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock1"
            app:layout_constraintStart_toStartOf="@+id/stepBlock1"
            android:layout_marginStart="60dp"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/stepLabel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Going up!"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock2"
            app:layout_constraintStart_toStartOf="@+id/stepBlock2"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock2"/>

        <ImageView
            android:id="@+id/stepBlock3"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock2"
            app:layout_constraintStart_toStartOf="@+id/stepBlock2"
            android:layout_marginStart="60dp"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/stepLabel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moving along!"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock3"
            app:layout_constraintStart_toStartOf="@+id/stepBlock3"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock3"/>

        <ImageView
            android:id="@+id/stepBlock4"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock3"
            app:layout_constraintStart_toStartOf="@+id/stepBlock3"
            android:layout_marginStart="60dp"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/stepLabel4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="So close!"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock4"
            app:layout_constraintStart_toStartOf="@+id/stepBlock4"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock4"/>

        <ImageView
            android:id="@+id/stepBlock5"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock4"
            app:layout_constraintStart_toStartOf="@+id/stepBlock4"
            android:layout_marginStart="60dp"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/stepLabel5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We did it!"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock5"
            app:layout_constraintStart_toStartOf="@+id/stepBlock5"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock5"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:text="Play Again"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_background_g"
            android:textColor="@android:color/white"
            android:elevation="4dp"
            android:alpha="0"/>

        <Button
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Routine Selection"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_background"
            android:textColor="@android:color/white"
            android:elevation="4dp"
            android:alpha="0"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>