<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/staircaseContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/activity_scoreboard_bg"
    android:padding="16dp">

    <TextView
        android:id="@+id/therapeuticMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Score"
        android:textSize="35dp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/motivationalQuote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="italic"
        android:textColor="@color/black"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/therapeuticMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <!-- Centered Container for Stairs -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/stairsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/motivationalQuote"
        app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
        app:layout_constraintVertical_weight="1">

        <!-- Star Character -->
        <ImageView
            android:id="@+id/starCharacter"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/score_star"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock1"
            app:layout_constraintStart_toStartOf="@+id/stepBlock1"
            android:layout_marginBottom="10dp"/>

        <!-- Step 1 (BOTTOM) -->
        <ImageView
            android:id="@+id/stepBlock1"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="30dp"
            android:layout_marginBottom="80dp"/>

        <TextView
            android:id="@+id/stepLabel1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock1"
            app:layout_constraintStart_toStartOf="@+id/stepBlock1"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock1"
            android:layout_marginBottom="5dp"/>

        <!-- Step 2 -->
        <ImageView
            android:id="@+id/stepBlock2"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock1"
            app:layout_constraintStart_toStartOf="@+id/stepBlock1"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/stepLabel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 2"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock2"
            app:layout_constraintStart_toStartOf="@+id/stepBlock2"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock2"
            android:layout_marginBottom="5dp"/>

        <!-- Step 3 -->
        <ImageView
            android:id="@+id/stepBlock3"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock2"
            app:layout_constraintStart_toStartOf="@+id/stepBlock2"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/stepLabel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 3"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock3"
            app:layout_constraintStart_toStartOf="@+id/stepBlock3"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock3"
            android:layout_marginBottom="5dp"/>

        <!-- Step 4 -->
        <ImageView
            android:id="@+id/stepBlock4"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock3"
            app:layout_constraintStart_toStartOf="@+id/stepBlock3"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/stepLabel4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 4"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock4"
            app:layout_constraintStart_toStartOf="@+id/stepBlock4"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock4"
            android:layout_marginBottom="5dp"/>

        <!-- Step 5 (TOP) -->
        <ImageView
            android:id="@+id/stepBlock5"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:src="@drawable/staircase_block"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock4"
            app:layout_constraintStart_toStartOf="@+id/stepBlock4"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/stepLabel5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 5"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/stepBlock5"
            app:layout_constraintStart_toStartOf="@+id/stepBlock5"
            app:layout_constraintEnd_toEndOf="@+id/stepBlock5"
            android:layout_marginBottom="5dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:text="Play Again"
            android:background="@drawable/rounded_button_background_g"
            android:textColor="@android:color/white"
            android:alpha="0"/>

        <Button
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:background="@drawable/rounded_button_background"
            android:textColor="@android:color/white"
            android:alpha="0"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>