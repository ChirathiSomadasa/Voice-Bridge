<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ActivitySequenceUnderActivity">

    <!-- Bubble Progress Bar (Top floating bubbles) -->
    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="411dp"
        android:layout_height="39dp"
        android:background="@drawable/bubble_container_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Bubbles will be added programmatically -->
    </LinearLayout>

    <!-- Top Game Image without overlay text -->
    <ImageView
        android:id="@+id/topGameImage"
        android:layout_width="425dp"
        android:layout_height="234dp"
        android:alpha="0.9"
        android:scaleType="fitXY"
        android:src="@drawable/activity_sequence"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bubbleContainer" />

    <TextView
        android:id="@+id/game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Therapeutic Sequencing"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/title_background"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/topGameImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Therapeutic hint indicator -->
    <ImageView
        android:id="@+id/hintIndicator"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_no_hint"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/topGameImage"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top bar with Timer and Control buttons in same line -->
    <LinearLayout
        android:id="@+id/topControlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/game_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Timer display on left -->
        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:background="@drawable/timer_background"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginEnd="16dp" />

        <!-- Spacer to push control buttons to the right -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Control buttons on right -->
        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Undo"
            android:backgroundTint="@color/dark_orange"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp"
            android:elevation="2dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Clear All"
            android:backgroundTint="@color/pink"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Visual hint overlay (circular glow) -->
    <View
        android:id="@+id/visualHintOverlay"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/glowing_circle"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Main content scrollable container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topControlBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Instruction text -->
            <TextView
                android:id="@+id/tv_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap the images in correct order"
                android:textSize="18sp"
                android:textColor="@color/green"
                android:gravity="center"
                android:padding="16dp"
                android:background="@drawable/instruction_background"
                android:layout_marginBottom="16dp" />

            <!-- Horizontal images (initial learning state) - CORRECT ORDER -->
            <LinearLayout
                android:id="@+id/horizontal_images_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:weightSum="3">

                <!-- Images will be populated dynamically based on routine -->
                <!-- Placeholder structure - Made larger for children -->
                <FrameLayout
                    android:id="@+id/horizontal_frame_1"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/image_container_bg">

                    <ImageView
                        android:id="@+id/horizontal_img_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:adjustViewBounds="true"
                        android:padding="12dp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/horizontal_frame_2"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/image_container_bg">

                    <ImageView
                        android:id="@+id/horizontal_img_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:adjustViewBounds="true"
                        android:padding="12dp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/horizontal_frame_3"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/image_container_bg">

                    <ImageView
                        android:id="@+id/horizontal_img_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:adjustViewBounds="true"
                        android:padding="12dp" />
                </FrameLayout>
            </LinearLayout>

            <!-- START BUTTON -->
            <Button
                android:id="@+id/btn_start"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="START"
                android:layout_gravity="center"
                app:backgroundTint="@color/dark_orange"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:layout_marginBottom="32dp"
                android:elevation="4dp" />

            <!-- Vertical images container (gameplay state) - JUMBLED ORDER -->
            <LinearLayout
                android:id="@+id/vertical_images_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <!-- Vertical images will be added programmatically here -->
                <!-- Each will be a FrameLayout containing ImageView and badge TextView -->
            </LinearLayout>

            <!-- Order display (showing selected sequence) -->
            <LinearLayout
                android:id="@+id/order_display_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/order_display_bg"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Sequence:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_orange"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_order_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. "
                    android:textSize="20sp"
                    android:textColor="@color/green"
                    android:paddingVertical="8dp"
                    android:gravity="center" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="4dp" />

                <TextView
                    android:id="@+id/tv_order_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. "
                    android:textSize="20sp"
                    android:textColor="@color/green"
                    android:paddingVertical="8dp"
                    android:gravity="center" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="4dp" />

                <TextView
                    android:id="@+id/tv_order_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3. "
                    android:textSize="20sp"
                    android:textColor="@color/green"
                    android:paddingVertical="8dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Therapeutic tips section -->
            <LinearLayout
                android:id="@+id/therapeuticTipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/tips_background"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Therapeutic Tip"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:drawableStart="@drawable/ic_tip"
                    android:drawablePadding="8dp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/therapeuticTipText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Take your time and focus on one step at a time."
                    android:textSize="16sp"
                    android:textColor="@color/dark_orange"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Space for dynamic content -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating action button for hint (when enabled) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_help"
        android:visibility="gone"
        app:backgroundTint="@color/green"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp" />

    <!-- Therapeutic overlay for celebrations -->
    <FrameLayout
        android:id="@+id/celebrationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Celebration content added programmatically -->
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>