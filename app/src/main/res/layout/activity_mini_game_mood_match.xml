<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MiniGameMoodMatchActivity">

        <!-- ── Header Banner ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/mgHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/dark_orange"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="20dp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/mgTvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ Bonus Round!"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:shadowColor="#00000066"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />

            <TextView
                android:id="@+id/mgTvInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Which emotion is this?"
                android:textColor="#FFE8CC"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/mgTvRound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Round 1 / 3"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/mgTvBonus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bonus: +0"
                    android:textColor="#FFE8CC"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="end" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── Scrollable Content ─────────────────────────────────────────────── -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/mgHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="20dp">

                <!-- Main Image (face or scenario) -->
                <ImageView
                    android:id="@+id/mgIvMain"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/panda_confused" />

                <!-- Feedback icon (star / sad panda) shown after answering -->
                <ImageView
                    android:id="@+id/mgIvFeedback"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="fitCenter"
                    android:visibility="invisible"
                    android:layout_marginBottom="0dp" />

                <!-- Scenario text (only visible in TYPE 1) -->
                <TextView
                    android:id="@+id/mgTvScenario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#FFF3E0"
                    android:padding="14dp"
                    android:text=""
                    android:textColor="#5D4037"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:visibility="gone" />

                <!-- Feedback text (Correct! / Not quite!) -->
                <TextView
                    android:id="@+id/mgTvFeedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Correct!"
                    android:textColor="@color/green"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:visibility="invisible" />

                <!-- 2×2 Answer Buttons -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/mgBtn1"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="6dp"
                        android:text="Happy"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/dark_orange"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/mgBtn2"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="6dp"
                        android:text="Sad"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/dark_orange"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/mgBtn3"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="6dp"
                        android:text="Angry"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/dark_orange"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/mgBtn4"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="6dp"
                        android:text="Scared"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/dark_orange"
                        android:stateListAnimator="@null" />

                </GridLayout>

                <!-- Next / Done button -->
                <Button
                    android:id="@+id/mgBtnNext"
                    android:layout_width="180dp"
                    android:layout_height="58dp"
                    android:layout_marginTop="20dp"
                    android:text="Next"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/green"
                    android:stateListAnimator="@null"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>