<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".ParentReportActivity">

    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bottom_bg"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:text="Student Speech Progress"
        android:textColor="#0A610D"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course Completion"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#263238"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvLevel1Progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 1: Letters"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginBottom="4dp"/>
                    <ProgressBar
                        android:id="@+id/pbLevel1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressDrawable="@drawable/custom_progressbar_green"
                        android:progress="0"
                        android:max="26"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvLevel2Progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 2: Words"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginBottom="4dp"/>
                    <ProgressBar
                        android:id="@+id/pbLevel2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressDrawable="@drawable/custom_progressbar_orange"
                        android:progress="0"
                        android:max="25"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvLevel3Progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 3: Sentences"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginBottom="4dp"/>
                    <ProgressBar
                        android:id="@+id/pbLevel3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressDrawable="@drawable/custom_progressbar_red"
                        android:progress="0"
                        android:max="30"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvCourseNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note: Course completion tracks passed levels (Score > 75%)."
                android:textSize="12sp"
                android:textColor="#78909C"
                android:background="#ECEFF1"
                android:padding="10dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Average Accuracy"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#263238"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="24dp">

                <include layout="@layout/card_score_summary" android:id="@+id/cardLetters"/>
                <include layout="@layout/card_score_summary" android:id="@+id/cardWords"/>
                <include layout="@layout/card_score_summary" android:id="@+id/cardSentences"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Areas for Improvement"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Issues detected in recent practice sessions:"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp"
                android:overScrollMode="never"
                tools:itemCount="5"
                tools:listitem="@layout/item_weakness_row"/>

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Great job! No significant weaknesses detected recently."
                android:gravity="center"
                android:padding="30dp"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadPdf"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="PDF"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:icon="@android:drawable/stat_sys_download"
            app:backgroundTint="#2196F3"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareReport"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Share"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_menu_share"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>