<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ActivitySequenceOverActivity">

    <!-- Bubble Progress Bar -->
    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="411dp"
        android:layout_height="-8dp"
        android:background="@drawable/bubble_container_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Game Image -->
    <ImageView
        android:id="@+id/topGameImage"
        android:layout_width="425dp"
        android:layout_height="234dp"
        android:alpha="0.9"
        android:scaleType="fitXY"
        android:src="@drawable/activity_sequence"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bubbleContainer" />

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Back"
        app:srcCompat="@drawable/back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Therapeutic Sequencing"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/title_background"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/topGameImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Top control bar -->
    <LinearLayout
        android:id="@+id/topControlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/game_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:background="@drawable/timer_background"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginEnd="16dp" />

        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Undo"
            android:backgroundTint="@color/dark_orange"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Clear All"
            android:backgroundTint="@color/pink"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topControlBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Instruction -->
            <TextView
                android:id="@+id/tv_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read and remember the order!"
                android:textSize="18sp"
                android:textColor="@color/green"
                android:gravity="center"
                android:padding="16dp"
                android:background="@drawable/instruction_background"
                android:layout_marginBottom="16dp" />

            <!-- Phase 1: preview cards -->
            <LinearLayout
                android:id="@+id/horizontal_images_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/preview_card_1"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/image_container_bg">
                    <TextView
                        android:id="@+id/preview_num_1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/preview_text_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Step 1"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/preview_card_2"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/image_container_bg">
                    <TextView
                        android:id="@+id/preview_num_2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="2"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/preview_text_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Step 2"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/preview_card_3"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/image_container_bg">
                    <TextView
                        android:id="@+id/preview_num_3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="3"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/preview_text_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Step 3"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />
                </LinearLayout>
            </LinearLayout>

            <!-- START button -->
            <Button
                android:id="@+id/btn_start"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="I'm Ready! Let's Go!"
                android:layout_gravity="center"
                app:backgroundTint="@color/dark_orange"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp" />

            <!-- Phase 2: Drop zones (hidden initially) -->
            <LinearLayout
                android:id="@+id/drop_zones_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Put steps in order:"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/drop_zone_1"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/order_display_bg">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/drop_text_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Drop here…"
                        android:textSize="16sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/drop_zone_2"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/order_display_bg">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="2"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/drop_text_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Drop here…"
                        android:textSize="16sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/drop_zone_3"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="@drawable/order_display_bg">
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="3"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/circular_dot" />
                    <TextView
                        android:id="@+id/drop_text_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Drop here…"
                        android:textSize="16sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>
            </LinearLayout>

            <!-- Phase 2: Draggable cards container -->
            <LinearLayout
                android:id="@+id/vertical_images_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/drag_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Drag these steps:"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <!-- Draggable cards added programmatically -->
            </LinearLayout>

            <!-- Therapeutic tips -->
            <LinearLayout
                android:id="@+id/therapeuticTipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/tips_background"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Therapeutic Tip"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:drawableStart="@drawable/ic_tip"
                    android:drawablePadding="8dp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/therapeuticTipText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Take your time and focus on one step at a time."
                    android:textSize="16sp"
                    android:textColor="@color/dark_orange"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="40dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hint FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_help"
        android:visibility="gone"
        app:backgroundTint="@color/green"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp" />

    <!-- Celebration overlay -->
    <FrameLayout
        android:id="@+id/celebrationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>