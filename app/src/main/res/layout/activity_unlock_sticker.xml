<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".UnlockStickerActivity">

    <!-- Glow Overlay -->
    <ImageView
        android:id="@+id/glowOverlay"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:src="@drawable/glow_circle"
        android:visibility="invisible"
        android:elevation="5dp" />

    <!-- Gift Box -->
    <ImageView
        android:id="@+id/giftBox"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:src="@drawable/gift_box"
        android:visibility="visible"
        android:elevation="10dp" />

    <!-- Blank Sticker Card -->
    <ImageView
        android:id="@+id/stickerCard"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center"
        android:src="@drawable/sticker_card_blank"
        android:visibility="invisible"
        android:elevation="15dp" />

    <!-- Sticker Reveal -->
    <ImageView
        android:id="@+id/stickerReveal"
        android:layout_width="420dp"
        android:layout_height="420dp"
        android:layout_gravity="center"
        android:src="@drawable/sticker"
        android:visibility="invisible"
        android:elevation="20dp" />

    <!-- Unlocked Text -->
    <TextView
        android:id="@+id/unlockedText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:text="NEW STICKER UNLOCKED!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/gold"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="15dp"
        android:shadowColor="@android:color/black"
        android:shadowRadius="4"
        android:shadowDx="2"
        android:shadowDy="2" />

    <!-- Collect Button -->

    <!-- Title Text -->
    <Button
        android:id="@+id/collectButton"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="20dp"
        android:background="@drawable/button_collect_gradient"
        android:elevation="10dp"
        android:text="COLLECT"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="570dp"
        android:text="Collect 2 More to \nUnlock New Routine!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="15dp"
        android:shadowColor="@android:color/black"
        android:shadowRadius="4"
        android:shadowDx="2"
        android:shadowDy="2" />

    <!-- Buttons Container for Replay and Dashboard -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone">

        <Button
            android:id="@+id/replayButton"
            android:layout_width="180dp"
            android:layout_height="70dp"
            android:layout_marginEnd="20dp"
            android:text="REPLAY"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/green_dark"
            android:elevation="10dp"/>

        <Button
            android:id="@+id/dashboardButton"
            android:layout_width="180dp"
            android:layout_height="70dp"
            android:text="DASHBOARD"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/dark_orange"
            android:elevation="10dp"/>

    </LinearLayout>

</FrameLayout>