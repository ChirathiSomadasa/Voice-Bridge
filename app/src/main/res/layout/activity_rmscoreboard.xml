<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF">

    <!-- Background Pattern -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_pattern"
        android:alpha="0.1"/>

    <!-- Title Text -->
    <TextView
        android:id="@+id/resultText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_gravity="center_horizontal"
        android:text="Amazing!"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:shadowColor="#40000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"/>

    <!-- Effort Message -->
    <TextView
        android:id="@+id/effortMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:layout_gravity="center_horizontal"
        android:text="You worked really hard!"
        android:textSize="20sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingHorizontal="24dp"/>

    <!-- Candy Jar Container -->
    <FrameLayout
        android:id="@+id/candyJarContainer"
        android:layout_width="300dp"
        android:layout_height="400dp"
        android:layout_marginTop="180dp"
        android:layout_gravity="center_horizontal">

        <!-- Empty Jar -->
        <ImageView
            android:id="@+id/candyJarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/empty_jar"/>

        <!-- Candies will be added programmatically -->
    </FrameLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/jarFillProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="250dp"
        android:layout_height="20dp"
        android:layout_marginTop="580dp"
        android:layout_gravity="center_horizontal"
        android:progressDrawable="@drawable/progress_bar_style"
        android:progress="0"/>

    <!-- Candy Count -->
    <TextView
        android:id="@+id/candyCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="540dp"
        android:layout_gravity="center_horizontal"
        android:text="0 candies"
        android:textSize="24sp"
        android:textColor="#FF6B35"
        android:textStyle="bold"/>

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:spacing="24dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/replayButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/rounded_button_background_g"
            android:text="PLAY AGAIN"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/dashboardButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/rounded_button_background"
            android:text="DASHBOARD"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"/>

    </LinearLayout>

    <!-- Sparkles Container -->
    <FrameLayout
        android:id="@+id/sparklesContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</FrameLayout>