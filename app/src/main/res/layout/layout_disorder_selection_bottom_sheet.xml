<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bottom_sheet_rounded_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Child Profile"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />


        <!-- Disorder Type Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Disorder Type"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupDisorders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:orientation="vertical"
            android:textStyle="bold">

            <RadioButton
                android:id="@+id/rbDisorderASD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Autism Spectrum Disorder"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderDS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Down Syndrome"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderArticulation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Articulation Disorder"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderPhono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Phonological Disorder"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderSpeechDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Speech Delay"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderStuttering"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Stuttering"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbDisorderLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Language Disorder"
                android:textStyle="bold"
                android:textSize="15sp" />

        </RadioGroup>


        <!-- Severity Selection (Initially Hidden) -->
        <TextView
            android:id="@+id/tvSeverityTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Severity Level"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupSeverity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:orientation="horizontal"
            android:textStyle="bold">

            <RadioButton
                android:id="@+id/rbSeverityMild"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="Mild"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbSeverityModerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="Moderate"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbSeveritySevere"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="Severe"
                android:textStyle="bold"
                android:textSize="15sp" />

        </RadioGroup>


        <!-- Communication Diff Selection (Initially Hidden) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Communication"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <RadioGroup
                android:id="@+id/radioGroupCommunicationRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:orientation="horizontal"
                android:textStyle="bold">

                <RadioButton
                    android:id="@+id/rbCommNonVerbal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:text="Non-verbal"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbCommFewWords"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:text="Few Words"
                    android:textStyle="bold"
                    android:textSize="15sp" />

            </RadioGroup>

            <RadioGroup
                android:id="@+id/radioGroupCommunicationRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:orientation="horizontal"
                android:textStyle="bold">

                <RadioButton
                    android:id="@+id/rbCommPhrases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:text="Phrases"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbCommSentences"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:text="Sentences"
                    android:textStyle="bold"
                    android:textSize="15sp" />

            </RadioGroup>
        </LinearLayout>


        <!-- Attention Selection (Initially Hidden) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Attention"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupAttention"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:orientation="horizontal"
            android:textStyle="bold">

            <RadioButton
                android:id="@+id/rbAttLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="Low"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbAttMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="Medium"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbAttHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:padding="12dp"
                android:text="High"
                android:textStyle="bold"
                android:textSize="15sp" />

        </RadioGroup>



        <Button
            android:id="@+id/btnApplyDisorder"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/green"
            android:text="Save and Continue"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>