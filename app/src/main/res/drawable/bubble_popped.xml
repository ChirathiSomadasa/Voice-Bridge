<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bubble outline (broken) -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#0288D1"
                android:dashWidth="4dp"
                android:dashGap="2dp" />
            <size
                android:width="60dp"
                android:height="60dp" />
        </shape>
    </item>
    <!-- Small droplets -->
    <item android:top="10dp" android:left="10dp">
        <shape android:shape="oval">
            <solid android:color="#B3E5FC" />
            <size
                android:width="8dp"
                android:height="8dp" />
        </shape>
    </item>
    <item android:top="40dp" android:left="20dp">
        <shape android:shape="oval">
            <solid android:color="#B3E5FC" />
            <size
                android:width="6dp"
                android:height="6dp" />
        </shape>
    </item>
</layer-list>