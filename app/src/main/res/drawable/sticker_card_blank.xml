<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Drop shadow -->
    <item
        android:left="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Card background -->
    <item
        android:bottom="4dp"
        android:right="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FFF8E1"
                android:centerColor="#FFFFFF"
                android:endColor="#FFF3E0"
                android:type="linear" />
            <stroke
                android:width="3dp"
                android:color="#FFD166" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Inner glow border -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#FFECB3" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>